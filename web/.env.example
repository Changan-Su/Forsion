# Tangu Web 环境变量示例 —— 复制为 .env(已 gitignore)。全部可选,不填走默认。

# ── dev(vite.config.ts 经 loadEnv 读本文件;也可 shell 前缀覆盖)────────────────
# dev server 端口。默认 5273;strictPort=true(占用即报错不自动切),撞端口就改这里。
PORT=5273
# dev 反代目标 = Forsion server。/api /auth /account 等都代理到这(同源化免 CORS)。
TANGU_DEV_PROXY=http://localhost:3001

# ── 运行时(webShim,浏览器侧,import.meta.env,须 VITE_ 前缀才注入 bundle)────────
# API 基址覆盖。不填 = location.origin + '/api'(dev 走上面的反代,prod 走容器 nginx)。
# 一般只在「前端与后端不同源」时才设,例如直连远端:https://api.forsion.net/api
# VITE_API_URL=

# ── prod(nginx 容器,由 docker-entrypoint.sh envsubst 注入;经 -e / compose 传入)──
# 同一个 PORT 变量:容器内 nginx 监听端口(默认 80)。改了记得同步映射 -p <host>:<PORT>。
# BACKEND_URL:容器里 /api /auth 反代到的 Forsion server(默认 host.docker.internal:3001)。
# BACKEND_URL=http://host.docker.internal:3001
# NGINX_RESOLVER:变量式 proxy_pass 所需 DNS(默认取容器 resolv.conf,兜底 127.0.0.11)。
